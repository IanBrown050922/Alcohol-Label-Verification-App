OPENAI_API_KEY=sk-api-key-here
OPENAI_MODEL=gpt-5.4-nano

# Fallback if gpt-5.4-nano is unavailable or quality is insufficient:
# OPENAI_MODEL=gpt-5.4-mini

OPENAI_TIMEOUT_SECONDS=30
MAX_IMAGES_PER_UNIT=10
MAX_IMAGE_MB=10
MAX_ZIP_MB=100
MAX_BATCH_UNITS=50
IMAGE_MAX_SIDE_PX=1600
IMAGE_JPEG_QUALITY=82

# Local UI testing only. This does not inspect image contents.
ALV_MOCK_OPENAI=false
